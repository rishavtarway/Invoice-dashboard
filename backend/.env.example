NODE_ENV=development
PORT=4000

# Local MongoDB:
MONGO_URI=mongodb://127.0.0.1:27017/invoice_dashboard

# Or MongoDB Atlas (replace <user>, <pass>, <cluster>):
# MONGO_URI=mongodb+srv://<user>:<pass>@<cluster>.mongodb.net/invoice_dashboard?retryWrites=true&w=majority

# Comma-separated allowed origins. For local dev this is fine as-is.
# For production, set to your Vercel frontend URL, e.g. https://invoice-dashboard.vercel.app
CORS_ORIGIN=http://localhost:5173
